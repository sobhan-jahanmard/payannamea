{
  "profile_key": "proposal",
  "order_type": "پروپوزال پایان‌نامه",
  "workflow": "codex/workflows/proposal_workflow.md",
  "required_fields": ["faculty", "advisor_name", "abstract"],
  "producer_agents": [
    "rule_extractor",
    "reference_reader",
    "visual_extractor",
    "image_researcher",
    "outline_builder",
    "chapter_support_writer",
    "academic_editor",
    "word_format_editor",
    "compliance_reporter"
  ],
  "checker_agents": [
    "profile_stage_checker",
    "proposal_methodology_checker",
    "citation_checker",
    "format_checker",
    "visual_loop_tester",
    "image_quality_checker",
    "ui_quality_checker"
  ],
  "skills": [
    "proposal rule extraction",
    "research question and objective alignment",
    "methodology feasibility checking",
    "source-grounded proposal drafting",
    "RTL DOCX formatting"
  ],
  "required_outputs": [
    "deliverable_source",
    "docx",
    "compliance_report",
    "reference_usage_report",
    "human_review_checklist",
    "final_readme"
  ],
  "image_policy": {
    "mode": "default_from_quantity",
    "require_sources_when_figures_expected": true,
    "allow_generated_images": false,
    "preferred_sources": ["customer_files", "Wikimedia Commons", "institutional_sources"]
  },
  "stage_check_policy": {
    "independent_checker_required": true,
    "loop_until_pass_or_human_review": true,
    "write_stage_reports": true
  },
  "external_tool_candidates": [
    {
      "name": "GROBID",
      "purpose": "Scientific PDF metadata/reference extraction",
      "url": "https://grobid.readthedocs.io/en/latest/Introduction/"
    },
    {
      "name": "PaperQA2",
      "purpose": "Source-grounded literature question answering over supplied papers",
      "url": "https://github.com/future-house/paper-qa"
    },
    {
      "name": "Pandoc or LibreOffice",
      "purpose": "Document conversion when native worker packaging is insufficient",
      "url": "https://pandoc.org/"
    }
  ]
}
