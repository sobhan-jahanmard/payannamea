# Unified Next.js app configuration.
# Copy to frontend/.env.local and fill the Supabase Postgres URL.

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/postgres?sslmode=require
AUTH_SECRET=change-this-local-secret
WORKER_API_KEY=local-worker-dev-key
STORAGE_DIR=storage

# Leave empty for same-origin API calls from the browser.
NEXT_PUBLIC_API_URL=

# Optional tuning for Supabase/Postgres connections.
DB_POOL_SIZE=5
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=30000
WORKER_LOCK_MINUTES=60
MAX_UPLOAD_SIZE_MB=50
